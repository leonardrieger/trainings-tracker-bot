# Von @BotFather beim Erstellen des Bots erhalten
TELEGRAM_BOT_TOKEN=

# Aus dem Supabase-Projekt: Settings -> API -> Project API keys -> "service_role" (secret!)
# NICHT den "anon"/"publishable" Key verwenden - der ist für Client-seitigen Code gedacht.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Deine eigene Telegram-User-ID (z.B. via @userinfobot herausfinden)
ALLOWED_TELEGRAM_USER_ID=

# Kostenloser API-Key von console.groq.com (Settings -> API Keys).
# Optional: ohne Key fällt der Bot automatisch auf den Regex-Parser zurück.
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Zufälliger String, schützt /cron/tick (Keep-Alive + Erinnerungs-Trigger)
CRON_SECRET=

# Zufälliger String; beim setWebhook als secret_token mitgeben (siehe README),
# schützt /webhook vor gefälschten POSTs
TELEGRAM_WEBHOOK_SECRET=

# Zufälliger String, schützt /dashboard
DASHBOARD_TOKEN=
